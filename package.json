{
  "name": "synthetics-monitor-extractor",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run --watch src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "docker:build": "docker build -t synthetics-monitor-extractor .",
    "docker:run": "docker run -p 9090:9090 synthetics-monitor-extractor",
    "docker:security": "snyk container test synthetics-monitor-extractor --severity-threshold=high",
    "security:scan": "snyk test --severity-threshold=high",
    "security:scan:json": "snyk test --severity-threshold=high --json > snyk-results.json || true",
    "security:scan:sarif": "snyk test --severity-threshold=high --sarif-file-output=snyk-results.sarif || true",
    "security:code": "snyk code test --severity-threshold=high",
    "security:code:json": "snyk code test --severity-threshold=high --json > snyk-code-results.json || true",
    "security:code:sarif": "snyk code test --severity-threshold=high --sarif-file-output=snyk-code-results.sarif || true",
    "security:full": "bun run security:scan && bun run security:code && bun run security:scan:sarif && bun run security:code:sarif",
    "security:check": "bash scripts/security-check.sh",
    "lint": "biome check ./src",
    "format": "biome format --write ./src",
    "health": "curl -f http://localhost:9090/metrics || exit 1",
    "validate": "bun run src/scripts/validate-connections.ts",
    "test:connections": "bun run src/scripts/validate-connections.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/bun": "^1.2.18",
    "@types/hapi__catbox": "^12.1.0",
    "@types/hapi__shot": "^6.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@elastic/ecs-winston-format": "^1.5.3",
    "@elastic/elasticsearch": "^9.0.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.202.0",
    "@opentelemetry/auto-instrumentations-node": "^0.60.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.202.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.202.0",
    "@opentelemetry/exporter-prometheus": "^0.202.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.202.0",
    "@opentelemetry/instrumentation-http": "^0.202.0",
    "@opentelemetry/instrumentation-winston": "^0.47.0",
    "@opentelemetry/otlp-exporter-base": "^0.202.0",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-logs": "^0.203.0",
    "@opentelemetry/sdk-metrics": "^2.0.1",
    "@opentelemetry/sdk-node": "^0.202.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@opentelemetry/winston-transport": "^0.13.0",
    "@platformatic/kafka": "^1.7.0",
    "@platformatic/kafka-opentelemetry": "^0.1.0",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "zod": "^3.25.74"
  },
  "trustedDependencies": [
    "core-js",
    "protobufjs"
  ],
  "overrides": {
    "lodash": "^4.17.21",
    "inquirer": "^9.2.15",
    "semver": "^7.6.0",
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "minimatch": "^9.0.5",
    "glob": "^11.0.0",
    "path-to-regexp": "^8.2.0",
    "cookie": "^0.7.0",
    "axios": "^1.7.7",
    "jsonwebtoken": "^9.0.2",
    "express": "^4.21.1"
  }
}
