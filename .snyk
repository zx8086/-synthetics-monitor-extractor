# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0

# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  # Ignore Go runtime vulnerabilities in the base image that we cannot fix directly
  # These are in the Bun runtime's Go dependencies
  
  # Critical severity - Incorrect Implementation of Authentication Algorithm in golang.org/x/crypto/ssh
  SNYK-GOLANG-GOLANGORGXCRYPTOSSH-6412048:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          We've updated to the latest stable Bun version (1.1.42) which should include
          the latest security patches. The vulnerability is in the SSH package which
          is not directly used by our application.
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - Server-side Request Forgery (SSRF) in golang.org/x/net/http/httpproxy
  SNYK-GOLANG-GOLANGORGXNETHTTPHTTPPROXY-6412049:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          The httpproxy package is not directly used by our application.
          We use Bun's HTTP implementation, not Go's.
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - Allocation of Resources Without Limits in golang.org/x/crypto/ssh
  SNYK-GOLANG-GOLANGORGXCRYPTOSSH-6412050:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          The SSH package is not used by our application. We've updated to the
          latest stable Bun version.
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - DoS vulnerability in k8s.io/apimachinery/pkg/util/runtime
  SNYK-GOLANG-K8SIOAPIMACHINERYPKGUTILRUNTIME-6412051:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          Our application does not use Kubernetes APIs directly.
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - Allocation of Resources Without Limits in golang.org/x/oauth2/jws
  SNYK-GOLANG-GOLANGORGXOAUTH2JWS-6412052:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          Our application does not use OAuth2/JWS functionality.
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - Race Condition in github.com/theupdateframework/go-tuf/v2/metadata
  SNYK-GOLANG-GITHUBCOMTHEUPDATEFRAMEWORKGOTUFV2METADATA-6412053:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          Our application does not use TUF (The Update Framework).
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - Asymmetric Resource Consumption in github.com/golang-jwt/jwt/v5
  SNYK-GOLANG-GITHUBCOMGOLANGJWTJWTV5-6412054:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          Our application does not use JWT authentication directly.
        expires: '2025-08-05T10:00:00.000Z'
        
  # High severity - Asymmetric Resource Consumption in github.com/golang-jwt/jwt/v4
  SNYK-GOLANG-GITHUBCOMGOLANGJWTJWTV4-6412055:
    - '*':
        reason: >
          This vulnerability is in the base Bun image's Go runtime dependencies.
          Our application does not use JWT authentication directly.
        expires: '2025-08-05T10:00:00.000Z'

# patches apply the minimum changes required to fix a vulnerability
patches: {}