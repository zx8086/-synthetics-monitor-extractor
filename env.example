# Elasticsearch Configuration
ELASTIC_NODE=http://localhost:9200
ELASTIC_API_KEY_ID=
ELASTIC_API_KEY=
ELASTIC_MAX_RETRIES=5
ELASTIC_REQUEST_TIMEOUT=30000
ELASTIC_COMPRESSION=true
ELASTIC_SNIFF_ON_START=false
ELASTIC_REJECT_UNAUTHORIZED=true
ELASTIC_NAME=synthetics-extractor
ELASTIC_OPAQUE_ID_PREFIX=synthetics-extractor::

# Kafka Configuration
KAFKA_CLIENT_ID=synthetics-extractor
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_CONNECTION_TIMEOUT=3000
KAFKA_AUTHENTICATION_TIMEOUT=3000
KAFKA_REQUEST_TIMEOUT=30000
KAFKA_INITIAL_RETRY_TIME=1000
KAFKA_RETRIES=8
KAFKA_TOPIC_NAME=monitoring.raw.events
KAFKA_MAX_MESSAGE_SIZE=5242880

# Extraction Configuration
EXTRACTION_INTERVAL_MINUTES=10
EXTRACTION_TIME_RANGE=now-5m
EXTRACTION_MAX_RESULTS=1000
EXTRACTION_TIMEOUT=30s
EXTRACTION_INDEX_PATTERN=synthetics-*
EXTRACTION_MONITOR_NAME_PATTERN=*prd*

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=text
LOG_INCLUDE_TIMESTAMP=true

# Console Logging (stdout/stderr)
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_LEVEL=info

# OpenTelemetry Logging (follows OPEN_TELEMETRY_ENABLED setting)
LOG_OPENTELEMETRY_LEVEL=info

# Metrics Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PREFIX=synthetics_extractor_
METRICS_ENDPOINT=/metrics

# API Configuration
API_ENABLED=true
API_INVALID_RECORDS_ENDPOINT=/api/invalid-records
API_UI_ENDPOINT=/ui

# OpenTelemetry Configuration
OPEN_TELEMETRY_ENABLED=false
OPEN_TELEMETRY_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OPEN_TELEMETRY_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OPEN_TELEMETRY_LOGS_ENDPOINT=http://localhost:4318/v1/logs
OPEN_TELEMETRY_SERVICE_NAME=synthetics-monitor-extractor
OPEN_TELEMETRY_METRIC_INTERVAL_MS=15000

# Environment
NODE_ENV=development
